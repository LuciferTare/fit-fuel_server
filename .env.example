# Django
SECRET_KEY=your-django-secret-key-here

# JWT
JWT_SECRET_KEY=your-jwt-signing-secret-here
ACCESS_TOKEN_TIME=1440
REFRESH_TOKEN_TIME=10080

# Mode: development | production
DJANGO_ENV=development

# Database (MySQL)
HOST=localhost
DATABASE_NAME=your_db_name
DATABASE_USER=your_db_user
DATABASE_PASS=your_db_password
DATABASE_PORT=3306

# Email (SMTP)
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-app-password
DEFAULT_FROM_EMAIL=Your App <noreply@example.com>
SUPPORT_EMAIL=support@example.com

# App branding (used in email templates)
APP_NAME=Your App Name
LOGO_URL=https://example.com/logo.png

# Contact form receiver
CONTACT_US_EMAIL_RECEIVER=receiver@example.com
